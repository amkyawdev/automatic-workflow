# Automatic Workflow Backend - Environment Variables

# App Settings
APP_NAME="Automatic Workflow"
APP_VERSION="1.0.0"
DEBUG=false

# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/autoflow"
POSTGRES_USER="your_postgres_user"
POSTGRES_PASSWORD="your_postgres_password"
POSTGRES_DB="autoflow"

# Redis Cache
REDIS_URL="redis://localhost:6379"

# Security
SECRET_KEY="your-super-secret-key-change-in-production-min-32-chars"

# JWT Settings
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External APIs (Optional - for production)
OPENAI_API_KEY="sk-..."
SLACK_BOT_TOKEN="xoxb-..."
DISCORD_BOT_TOKEN="your-discord-bot-token"
GITHUB_TOKEN="ghp_..."

# CORS Origins (comma-separated)
CORS_ORIGINS="https://yourdomain.com,https://*.vercel.app"
